<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ManualDriveActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TableLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="50dp">

            <TableRow>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_span="3"
                    android:textAlignment="center"
                    android:textStyle="bold"
                    android:textSize="20dp"
                    android:text="Distance"/>
            </TableRow>

            <TableRow
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvDistanceLeft"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAlignment="center"
                    android:textSize="16dp"
                    android:layout_marginEnd="16dp"
                    android:text="Left"/>

                <TextView
                    android:id="@+id/tvDistanceMiddle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAlignment="center"
                    android:textSize="16dp"
                    android:layout_marginEnd="16dp"
                    android:text="Middle"/>

                <TextView
                    android:id="@+id/tvDistanceRight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAlignment="center"
                    android:textSize="16dp"
                    android:text="Right" />
            </TableRow>

<!--            <TableRow android:layout_height="20dp">-->
<!--                <View android:layout_height="20dp" />-->
<!--            </TableRow>-->

            <Space
                android:layout_width="match_parent"
                android:layout_height="24dp" />

            <TableRow
                android:orientation="vertical">
                <CheckBox android:id="@+id/cbChronometerEnabled"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="chronometer"
                    android:layout_span="3"
                    android:textSize="16sp" />
            </TableRow>

            <TableRow
                android:orientation="vertical">
                <Chronometer
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:layout_span="3"
                    android:id="@+id/cmChronometer" />
            </TableRow>


            <Space
                android:layout_width="match_parent"
                android:layout_height="24dp" />

            <TableRow
                android:orientation="vertical">
                <ImageButton
                    android:id="@+id/btnForwardLeft"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:scaleX="-1"
                    android:src="@drawable/ic_arrow_up_right_black" />
                <ImageButton
                    android:id="@+id/btnForward"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:src="@drawable/ic_arrow_up_black" />
                <ImageButton
                    android:id="@+id/btnForwardRight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:src="@drawable/ic_arrow_up_right_black" />
            </TableRow>

            <TableRow
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <ImageButton
                    android:id="@+id/btnRotateLeft"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:scaleX="-1"
                    android:src="@drawable/ic_rotate_right_black" />
                <ImageButton
                    android:id="@+id/btnStop"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_stop_black" />
                <ImageButton
                    android:id="@+id/btnRotateRight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_rotate_right_black" />
            </TableRow>

            <TableRow
                android:orientation="vertical">
                <ImageButton
                    android:id="@+id/btnBackwardLeft"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:scaleX="-1"
                    android:scaleY="-1"
                    android:src="@drawable/ic_arrow_up_right_black" />
                <ImageButton
                    android:id="@+id/btnBackward"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:scaleY="-1"
                    android:src="@drawable/ic_arrow_up_black" />
                <ImageButton
                    android:id="@+id/btnBackwardRight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:scaleY="-1"
                    android:src="@drawable/ic_arrow_up_right_black" />
            </TableRow>

            <TableRow
                android:layout_marginTop="60sp">
                <TextView
                    android:id="@+id/tvSpeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_span="3"
                    android:textAlignment="center"
                    android:text="@string/tv_speed_1"/>
            </TableRow>

            <TableRow>
                <SeekBar
                    android:id="@+id/seekBarSpeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_span="3"
                    android:min="1"
                    android:max="10"/>
            </TableRow>

        </TableLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
